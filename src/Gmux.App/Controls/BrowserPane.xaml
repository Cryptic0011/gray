<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Gmux.App.Controls.BrowserPane"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Address Bar -->
        <Grid Grid.Row="0" Padding="4" Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="&#xE72B;" FontFamily="Segoe MDL2 Assets"
                    x:Name="BackButton" Click="BackButton_Click"
                    Padding="8,4" Margin="0,0,2,0" />
            <Button Grid.Column="1" Content="&#xE72A;" FontFamily="Segoe MDL2 Assets"
                    x:Name="ForwardButton" Click="ForwardButton_Click"
                    Padding="8,4" Margin="0,0,2,0" />
            <Button Grid.Column="2" Content="&#xE72C;" FontFamily="Segoe MDL2 Assets"
                    x:Name="RefreshButton" Click="RefreshButton_Click"
                    Padding="8,4" Margin="0,0,4,0" />
            <TextBox Grid.Column="3" x:Name="AddressBar"
                     PlaceholderText="Enter URL..."
                     KeyDown="AddressBar_KeyDown" />
        </Grid>

        <!-- WebView2 -->
        <WebView2 Grid.Row="1" x:Name="WebView"
                  Source="https://localhost:3000" />
    </Grid>
</UserControl>
