<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Gmux.App.Controls.WorkspaceSidebar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="#1e1e19">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="16,12" BorderThickness="0,0,0,1"
                BorderBrush="#49483e">
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Image Source="/ico.ico" Width="24" Height="24" VerticalAlignment="Center" />
                <TextBlock Text="gray" FontSize="18" FontWeight="Bold"
                           Foreground="#f8f8f2" VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Workspace List -->
        <ListView
            x:Name="WorkspaceList"
            Grid.Row="1"
            SelectionMode="Single"
            Padding="4">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="8,8" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0"
                                    Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="{Binding Name}"
                                       FontWeight="SemiBold"
                                       Foreground="#f8f8f2"
                                       VerticalAlignment="Center" />
                            <Border Background="#f4bf75"
                                    CornerRadius="8"
                                    Padding="6,2"
                                    VerticalAlignment="Center"
                                    Visibility="{Binding BadgeVisibility}">
                                <TextBlock Text="{Binding UnreadCount}"
                                           FontSize="11" Foreground="#272822"
                                           FontWeight="Bold" />
                            </Border>
                        </StackPanel>

                        <!-- Workspace menu button -->
                        <Button Grid.Row="0" Grid.Column="1"
                                Content="&#x22EF;"
                                FontSize="14"
                                Padding="4,0"
                                MinWidth="0" MinHeight="0"
                                Background="Transparent"
                                Foreground="#75715e"
                                VerticalAlignment="Center"
                                Tag="{Binding Id}"
                                Click="WorkspaceMenu_Click">
                            <Button.Flyout>
                                <MenuFlyout x:Name="WorkspaceMenuFlyout">
                                    <MenuFlyoutItem Text="Rename" Tag="{Binding Id}" Click="RenameWorkspace_Click" />
                                    <MenuFlyoutItem Text="Delete" Tag="{Binding Id}" Click="DeleteWorkspace_Click" />
                                </MenuFlyout>
                            </Button.Flyout>
                        </Button>

                        <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                    Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="{Binding GitBranch}"
                                       FontSize="11" Foreground="#75715e"
                                       FontFamily="Cascadia Mono, Consolas" />
                            <TextBlock Text="{Binding ShortPath}"
                                       FontSize="11" Foreground="#49483e" />
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Footer Actions -->
        <StackPanel Grid.Row="2" Margin="8" Spacing="8">
            <Button
                x:Name="SettingsButton"
                Content="Settings"
                HorizontalAlignment="Stretch"
                Background="#3e3d32"
                Foreground="#f8f8f2"
                Click="SettingsButton_Click" />
            <Button Grid.Row="2"
                    Content="+ New Workspace"
                    HorizontalAlignment="Stretch"
                    Background="#49483e"
                    Foreground="#f8f8f2"
                    x:Name="NewWorkspaceButton"
                    Click="NewWorkspaceButton_Click" />
        </StackPanel>
    </Grid>
</UserControl>
