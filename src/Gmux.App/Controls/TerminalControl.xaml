<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Gmux.App.Controls.TerminalControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="#272822">
        <!-- Win2D CanvasControl is added from code-behind -->
        <Grid x:Name="CanvasHost" />

        <!-- Invisible TextBox for IME and clipboard support -->
        <TextBox
            x:Name="InputCapture"
            Opacity="0"
            Width="1"
            Height="1"
            HorizontalAlignment="Left"
            VerticalAlignment="Top" />
    </Grid>
</UserControl>
